{
  "manifest_version": 3,
  "name": "Imply Docs — Copy Markdown",
  "version": "1.0.0",
  "description": "Adds a Copy Markdown button to docs.imply.io pages for LLM-optimized content extraction.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.imply.io/*"],
      "js": ["turndown.js", "turndown-plugin-gfm.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
